# Copy this file to .env and fill in your keys.
# All three have free tiers.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (fast Llama) — https://console.groq.com/keys
GROQ_API_KEY=

# Sarvam AI (natural Indian Hindi TTS) — https://www.sarvam.ai/
SARVAM_API_KEY=

# Optional tuning
CODESENSEI_DEFAULT_VOICE=meera
CODESENSEI_DEFAULT_LANG=hinglish
CODESENSEI_THINK_SECONDS=180
