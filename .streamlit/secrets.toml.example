# Copy this to secrets.toml ONLY for local testing of the secrets path,
# OR paste these keys into the Streamlit Cloud "Secrets" UI when deploying.
# DO NOT commit secrets.toml — it's already in .gitignore.

GROQ_API_KEY       = "gsk_..."         # https://console.groq.com/keys (free, no card)
CEREBRAS_API_KEY   = "csk-..."         # https://cloud.cerebras.ai/?tab=api-keys (free, no card)
OPENROUTER_API_KEY = "sk-or-..."       # https://openrouter.ai/keys (free models available)
GEMINI_API_KEY     = "..."             # https://aistudio.google.com/apikey (free tier)
SARVAM_API_KEY     = "..."             # optional, for Hindi TTS narration

# Optional overrides (defaults are fine):
# DEFAULT_VOICE     = "amol"
# DEFAULT_LANG      = "hinglish"
# THINK_SECONDS     = "180"
# GROQ_MODEL        = "llama-3.3-70b-versatile"
# CEREBRAS_MODEL    = "llama-3.3-70b"
# OPENROUTER_MODEL  = "meta-llama/llama-3.3-70b-instruct:free"
# GEMINI_MODEL      = "gemini-2.0-flash"
